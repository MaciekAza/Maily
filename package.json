{
  "name": "maily",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@9.15.2",
  "engines": {
    "node": ">=24.11.0 <25",
    "pnpm": "9.15.2"
  },
  "scripts": {
    "prepare": "husky",
    "commitlint": "commitlint",
    "dev": "pnpm --recursive --parallel --if-present run dev",
    "build": "pnpm --recursive --if-present run build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "pnpm --recursive --if-present run typecheck",
    "test": "pnpm --recursive --if-present run test",
    "test:e2e": "pnpm --recursive --if-present run test:e2e",
    "format": "prettier . --write",
    "format:check": "prettier . --check"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "prettier": "3.9.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1"
  },
  "license": "MIT"
}
